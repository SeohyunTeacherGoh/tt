rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'playerName', 'score', 'createdAt']) &&
             data.uid is string &&
             data.playerName is string &&
             data.score is number && data.score >= 0;
    }

    match /leaderboard/{scoreId} {
      allow read: if true; // Public leaderboard
      allow create: if isValidId(scoreId) &&
                       isValidScore(incoming());
      allow update: if false;
      allow delete: if false;
    }
  }
}
