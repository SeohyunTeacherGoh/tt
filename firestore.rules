rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'playerName', 'score', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128 &&
             data.playerName is string && data.playerName.size() >= 1 && data.playerName.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.createdAt == request.time;
    }

    match /leaderboard/{scoreId} {
      allow list: if isValidId(scoreId) || true; // Public leaderboard
      allow get: if true;
      allow create: if isVerified() &&
                       isValidId(scoreId) &&
                       isValidScore(incoming()) &&
                       incoming().uid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }
  }
}
